# Database
DATABASE_URL=postgres://analytics:analytics_secret@localhost:5432/analytics?sslmode=disable
CLICKHOUSE_DSN=clickhouse://analytics:analytics_secret@localhost:9000/analytics
REDIS_URL=redis://localhost:6379/0

# API Configuration
PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ISSUER=analytics-platform
CORS_ORIGINS=http://localhost:3000

# Worker Configuration
BATCH_SIZE=5000
BATCH_TIMEOUT_MS=2000
CONSUMER_GROUP=analytics-workers
CONSUMER_NAME=worker-1

# Collector Configuration
RATE_LIMIT_RPS=10000

# Environment
ENVIRONMENT=development
LOG_LEVEL=info

# GeoIP (optional - download from MaxMind)
GEOIP_PATH=/app/data/GeoLite2-City.mmdb

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_COLLECTOR_URL=http://localhost:8081
